APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Asia/Kolkata

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

DB_TIMEZONE=Asia/Kolkata

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=database

# Use file cache for local dev so queue workers do not depend on the cache table.
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 Configuration (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=false
# R2 Public Development URL (bucket Settings → Public Development URL, e.g. https://pub-xxxx.r2.dev)
R2_PUBLIC_URL=

VITE_APP_NAME="${APP_NAME}"

# Optional: system-wide OpenAI defaults (used when a tenant has no override)
# OPENAI_API_KEY=
# OPENAI_GPT_MODEL=gpt-4
# OPENAI_WHISPER_MODEL=whisper-1

# Optional: system-wide Supabase Storage fallback (used when a tenant has no override)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-or-anon-key
# SUPABASE_BUCKET=your-bucket-name
# SUPABASE_VOICENOTES_BUCKET=voicenotes

# Email OTP (API): optional fixed 4-digit code (e.g. local testing). Unset = random in production; non-prod defaults to 2468 when unset.
# EMAIL_OTP_STATIC=

# Mobile API (Sanctum): Bearer token lifetime after email OTP verify (days)
SANCTUM_MOBILE_TOKEN_DAYS=30

# API docs (Scribe). UI: /docs · Postman JSON: /docs.postman · OpenAPI: /docs.openapi
# SCRIBE_AUTH_KEY=  # optional: Bearer token for Scribe "Try it out" on protected routes

# Email ingestion (IMAP via webklex/laravel-imap): enable PHP `imap` extension in php.ini
# Run scheduler: `php artisan schedule:run` every minute (cron) or `php artisan schedule:work`
# Queue: process the `default` queue so FetchEmailsJob / ProcessEmailJob run

# Zoho CRM (optional): API base + Accounts URLs must match the same region (.com, .in, .eu, etc.)
# Listing tags (/settings/tags) requires ZohoCRM.settings.tags.READ — add scopes in API Console too, then re-run tenant OAuth after changing scopes.
# ZOHO_OAUTH_SCOPES=ZohoCRM.users.READ,ZohoCRM.modules.ALL,ZohoCRM.settings.tags.READ
